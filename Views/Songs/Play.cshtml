@model SpotifyClone.Models.Song

@{
    ViewData["Title"] = "Play Song";
}

<div class="container mx-auto">
    <h2 class="text-3xl font-bold mb-8">@Model.Title</h2>
    <div class="flex items-center mb-8">
        @if (string.IsNullOrEmpty(Model.AlbumArtUrl))
        {
            <div class="w-48 h-48 mr-8 rounded bg-gray-600 flex items-center justify-center text-gray-400 text-sm">
                No Art
            </div>
        }
        else
        {
            <img src="@Model.AlbumArtUrl" alt="Album Art" class="w-48 h-48 mr-8 rounded" />
        }
        <div>
            <p class="text-xl">Artist: @Model.Artist</p>
            <p class="text-xl">Album: @Model.Album</p>
            <button onclick="playSongExt(@Model.Id, '@Model.Title', '@Model.Artist', '@Model.AlbumArtUrl', 'play-btn-@Model.Id')" class="bg-green-500 hover:bg-green-400 text-white px-6 py-3 rounded mt-4 relative song-card" id="play-btn-@Model.Id">
                <span class="play-spinner-@Model.Id hidden absolute inset-0 flex items-center justify-center">
                    <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                </span>
                <span class="play-icon-@Model.Id">Play Song</span>
            </button>
        </div>
    </div>
    <p><a asp-action="Index" class="text-green-500 hover:text-green-400">Back to Songs</a></p>
</div>