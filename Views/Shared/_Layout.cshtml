<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RuneWave</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-gray-900 text-white">
    <div id="sidebar" class="w-60 bg-black p-6 fixed h-screen overflow-y-auto z-50 hidden md:block">
        <div class="flex justify-between items-center mb-8">
            <a class="text-white text-2xl font-bold" asp-area="" asp-controller="Home" asp-action="Index">RuneWave</a>
            <button onclick="toggleSidebar()" class="md:hidden text-white text-2xl">&times;</button>
        </div>
        <ul class="space-y-4">
            <li>
                <a class="text-gray-300 hover:text-white block" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
            </li>
            @if (User.Identity.IsAuthenticated)
            {
                <li>
                    <a class="text-gray-300 hover:text-white block" asp-controller="Songs" asp-action="Index">Your Songs</a>
                </li>
                <li>
                    <a class="text-gray-300 hover:text-white block" asp-controller="Songs" asp-action="RecentlyPlayed">Recently Played</a>
                </li>
                <li>
                    <a class="text-gray-300 hover:text-white block" asp-controller="Songs" asp-action="Favorites">Favorites</a>
                </li>
                <li>
                    <a class="text-gray-300 hover:text-white block" asp-controller="Playlists" asp-action="Index">Your Playlists</a>
                </li>
                <li>
                    <a class="text-gray-300 hover:text-white block" asp-controller="Emissors" asp-action="Index">Online Radio</a>
                </li>
                <li>
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="text-gray-300 hover:text-white block bg-transparent border-none">Logout</button>
                    </form>
                </li>
            }
            else
            {
                <li>
                    <a class="text-gray-300 hover:text-white block" asp-controller="Account" asp-action="Login">Login</a>
                </li>
                <li>
                    <a class="text-gray-300 hover:text-white block" asp-controller="Account" asp-action="Register">Register</a>
                </li>
            }
        </ul>
    </div>
    <div class="ml-0 md:ml-60 p-6 bg-gray-900 min-h-screen pb-24">
        <button onclick="toggleSidebar()" class="md:hidden bg-gray-700 text-white p-2 rounded mb-4">☰</button>
        <main role="main">
            @RenderBody()
        </main>
    </div>
    <div class="fixed bottom-0 left-0 md:left-60 right-0 bg-gray-800 border-t border-gray-700 z-50">
        <div class="flex items-center h-24 px-3 md:px-4 max-w-screen-2xl mx-auto gap-2 md:gap-4">
            <div class="hidden md:flex items-center gap-3 min-w-0" style="width:30%">
                <div id="player-art" class="player-art">
                    <div class="player-art-placeholder">♪</div>
                </div>
                <div class="min-w-0">
                    <div id="player-song-title" class="text-white text-sm font-medium truncate leading-tight">No song playing</div>
                    <div id="player-artist" class="text-gray-400 text-xs truncate leading-tight mt-0.5"></div>
                </div>
            </div>

            <div class="flex flex-col items-center flex-1 min-w-0 gap-1">
                <div class="flex items-center gap-1 md:gap-2">
                    <button id="shuffle-btn" class="player-btn player-btn-sm" onclick="toggleShuffle()" title="Shuffle">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 3 21 3 21 8"/><line x1="4" y1="20" x2="21" y2="3"/><polyline points="21 16 21 21 16 21"/><line x1="15" y1="15" x2="21" y2="21"/><line x1="4" y1="4" x2="9" y2="9"/></svg>
                    </button>
                    <button id="prev-btn" class="player-btn player-btn-sm" onclick="prevSong()" title="Previous">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 6h2v12H6zm3.5 6l8.5 6V6z"/></svg>
                    </button>
                    <button id="play-pause-btn" class="player-btn-play" onclick="togglePlayPause()" title="Play/Pause">
                        <span id="play-spinner" class="hidden">
                            <svg class="animate-spin h-5 w-5" viewBox="0 0 24 24" fill="none">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
                            </svg>
                        </span>
                        <span id="play-icon">▶</span>
                    </button>
                    <button id="next-btn" class="player-btn player-btn-sm" onclick="nextSong()" title="Next">
                        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M6 18l8.5-6L6 6v12zM16 6v12h2V6h-2z"/></svg>
                    </button>
                    <div class="loop-btn-wrap">
                        <button id="loop-btn" class="player-btn player-btn-sm" onclick="toggleLoop()" title="Repeat off">
                            <svg id="loop-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 014-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 01-4 4H3"/></svg>
                        </button>
                        <span id="loop-badge" class="loop-badge hidden">1</span>
                    </div>
                </div>

                <div class="flex items-center gap-2 w-full max-w-lg">
                    <span id="player-current-time" class="text-gray-400 text-xs tabular-nums w-10 text-right select-none">0:00</span>
                    <div class="progress-wrap">
                        <div class="progress-track">
                            <div id="progress-fill" class="progress-fill"></div>
                        </div>
                        <div id="progress-thumb" class="progress-thumb"></div>
                        <input type="range" id="player-progress" min="0" max="100" value="0" oninput="seekTo(this.value)">
                    </div>
                    <span id="player-duration" class="text-gray-400 text-xs tabular-nums w-10 select-none">0:00</span>
                </div>
            </div>

            <div class="hidden md:flex items-center justify-end gap-2" style="width:30%">
                <button id="volume-btn" class="player-btn player-btn-sm" onclick="toggleMute()" title="Mute/Unmute">
                    <svg id="volume-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M19.07 4.93a10 10 0 010 14.14"/><path d="M15.54 8.46a5 5 0 010 7.07"/></svg>
                </button>
                <div class="progress-wrap" style="max-width:100px">
                    <div class="progress-track">
                        <div id="volume-fill" class="progress-fill" style="width:50%"></div>
                    </div>
                    <input type="range" id="volume-slider" min="0" max="100" value="50" oninput="setVolume(this.value)">
                </div>
                <div class="relative">
                    <button id="add-to-playlist-btn" class="player-btn player-btn-sm" onclick="showPlayerPlaylistMenu()" title="Add to playlist">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/player.js" asp-append-version="true"></script>
    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            sidebar.classList.toggle('hidden');
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
