@model IEnumerable<SpotifyClone.Models.Emissor>

@{
    ViewData["Title"] = "Online Radio";
}

<div class="container mx-auto">
    <h2 class="text-3xl font-bold mb-2">Online Radio</h2>
    <p class="text-gray-400 mb-8">Live radio from Dominican Republic and around the world</p>

    <div class="flex flex-wrap gap-4 mb-8">
        <form method="get" class="flex flex-wrap gap-4 w-full">
            <input type="text" name="search" value="@ViewBag.Search" placeholder="Search stations..." class="px-3 py-2 bg-gray-700 border border-gray-600 rounded text-white flex-1 min-w-[200px]" />

            <select name="country" class="px-3 py-2 bg-gray-700 border border-gray-600 rounded text-white" onchange="this.form.submit()">
                <option value="">All countries</option>
                @foreach (var c in ViewBag.Countries)
                {
                    <option value="@c" selected="@(c == ViewBag.SelectedCountry ? true : null)">@c</option>
                }
            </select>

            <select name="category" class="px-3 py-2 bg-gray-700 border border-gray-600 rounded text-white" onchange="this.form.submit()">
                <option value="">All genres</option>
                @foreach (var cat in ViewBag.Categories)
                {
                    <option value="@cat" selected="@(cat == ViewBag.SelectedCategory ? true : null)">@cat</option>
                }
            </select>

            <button type="submit" class="bg-green-500 hover:bg-green-400 text-white px-4 py-2 rounded">Filter</button>

            @if (!string.IsNullOrEmpty(ViewBag.Search) || !string.IsNullOrEmpty(ViewBag.SelectedCountry) || !string.IsNullOrEmpty(ViewBag.SelectedCategory))
            {
                <a asp-action="Index" class="bg-gray-600 hover:bg-gray-500 text-white px-4 py-2 rounded">Clear</a>
            }
        </form>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center text-gray-400 py-12">
            <p class="text-xl">No stations found</p>
            <p class="mt-2">Try different filters</p>
        </div>
    }

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var em in Model)
        {
            <div class="bg-gray-800 p-6 rounded-lg hover:bg-gray-750 transition-colors">
                <div class="flex items-start gap-4">
                    <div class="w-16 h-16 rounded-full bg-gray-600 flex-shrink-0 flex items-center justify-center text-2xl">
                        📻
                    </div>
                    <div class="min-w-0 flex-1">
                        <h5 class="text-xl font-semibold mb-1 truncate">@em.Name</h5>
                        <p class="text-gray-400 text-sm mb-1">@em.Country</p>
                        @if (!string.IsNullOrEmpty(em.Category))
                        {
                            <span class="inline-block bg-gray-700 text-gray-300 text-xs px-2 py-0.5 rounded">@em.Category</span>
                        }
                        @if (!string.IsNullOrEmpty(em.Description))
                        {
                            <p class="text-gray-500 text-xs mt-2 line-clamp-2">@em.Description</p>
                        }
                    </div>
                </div>
                <button onclick="playStreamUrl(@em.Id, '@em.Name?.Replace("'", "\\'")', '@em.Country?.Replace("'", "\\'")', 'play-btn-@em.Id')"
                        class="mt-4 bg-green-500 hover:bg-green-400 text-white px-4 py-2 rounded w-full relative"
                        id="play-btn-@em.Id">
                    <span class="play-spinner-@em.Id hidden absolute inset-0 flex items-center justify-center">
                        <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    </span>
                    <span class="play-icon-@em.Id">Listen</span>
                </button>
            </div>
        }
    </div>
</div>
